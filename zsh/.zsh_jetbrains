# @parameter subpath: Optional relative path below ~/dev/projects/java.
# @example: ij_proj_java
# @example: ij_proj_java coop-grade-management-system
# @notes: This is intended for non-training Java project work.
ij_proj_java() {
  open -a "IntelliJ IDEA" "$HOME/dev/projects/java/${1:-}"
}

